# Wrike API
WRIKE_PERMANENT_ACCESS_TOKEN=your_wrike_token_here

# GitHub API (fine-grained PAT, read-only commits + PRs)
GITHUB_TOKEN=your_github_pat_here

# Upstash Redis
UPSTASH_REDIS_REST_URL=your_upstash_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Vercel cron secret
CRON_SECRET=your_cron_secret_here

# Wrike webhook HMAC secret
WRIKE_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: Slack webhook for cron failure alerts
# NOTIFICATION_WEBHOOK_URL=https://hooks.slack.com/services/...

# PPC Analyser API (Railway backend)
PPC_API_URL=https://web-production-64f6a.up.railway.app
PPC_API_KEY=your_ppc_api_key_here
